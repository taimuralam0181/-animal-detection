DETECTION_PROVIDER=local
YOLO_MODEL=yolov8s-world.pt
# Default dataset upload limit is 12 GB.
MAX_DATASET_UPLOAD_BYTES=12884901888

# Google Cloud Vision
# Use a service account JSON file and point GOOGLE_APPLICATION_CREDENTIALS to it.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-service-account.json

# AWS Rekognition
# The app uses the normal AWS credential chain.
AWS_REGION=us-east-1
# Optional: use a Rekognition Custom Labels model instead of generic DetectLabels.
AWS_REKOGNITION_PROJECT_VERSION_ARN=

# Azure Custom Vision
AZURE_CUSTOM_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_CUSTOM_VISION_PREDICTION_KEY=
AZURE_CUSTOM_VISION_PROJECT_ID=
AZURE_CUSTOM_VISION_PUBLISHED_NAME=
